APP_NAME=Trading AI Agent
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# When EXECUTION_MODE != paper or REAL_TRADING_ENABLED=true the boot validator
# requires API_AUTH_ENABLED=true and API_KEY to be set to a non-default value.
API_AUTH_ENABLED=false
API_KEY=replace_me

# When EXECUTION_MODE != paper or REAL_TRADING_ENABLED=true the boot validator
# requires a non-SQLite DATABASE_URL (Postgres) so concurrent writes to the
# system-state can be serialized safely.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:55432/trading_agent

AI_PROVIDER=mock
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=replace_me
# Default to Flash: ~20-25x cheaper than Pro, 1-3s latency, sufficient for
# BUY/SELL/HOLD classification when context is pre-computed (EMAs, RSI, etc.).
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.1
GEMINI_TOP_P=0.9
GEMINI_MAX_OUTPUT_TOKENS=512
# 0 = thinking off (recommended). Flash 2.5 thinks by default and the thinking
# tokens come out of MAX_OUTPUT_TOKENS, which truncates the JSON. Leave at 0
# unless you have a specific reason to enable reasoning.
GEMINI_THINKING_BUDGET=0

TRADING_ENABLED=true
PAPER_TRADING_ENABLED=true
REAL_TRADING_ENABLED=false
EXECUTION_MODE=paper
# spot = no short openings; futures = long/short; margin = long/short with borrow.
TRADING_MARKET_TYPE=spot

MARKET_DATA_PROVIDER=binance
MARKET_DATA_TIMEOUT_SECONDS=5
MARKET_DATA_KLINE_LIMIT=100
MARKET_DATA_PRICE_CACHE_TTL_SECONDS=2

BINANCE_API_KEY=replace_me
BINANCE_API_SECRET=replace_me
BINANCE_TESTNET_BASE_URL=https://testnet.binance.vision
BINANCE_LIVE_BASE_URL=https://api.binance.com
BINANCE_FUTURES_TESTNET_BASE_URL=https://demo-fapi.binance.com
BINANCE_FUTURES_LIVE_BASE_URL=https://fapi.binance.com
BINANCE_MARGIN_LIVE_BASE_URL=https://api.binance.com
BINANCE_RECV_WINDOW=5000
BINANCE_MAX_RETRIES=3
BINANCE_RETRY_BACKOFF_SECONDS=0.5
BINANCE_USE_TEST_ORDER_ENDPOINT=false
BINANCE_ORDER_TYPE=market
BINANCE_LIMIT_TIME_IN_FORCE=IOC
BINANCE_FUTURES_POSITION_MODE=one_way
BINANCE_MARGIN_ISOLATED=true
BINANCE_PLACE_OCO_PROTECTION=false
BINANCE_STOP_LIMIT_SLIPPAGE_PERCENT=0.1
BINANCE_USER_STREAM_ENABLED=false
BINANCE_TESTNET_WS_BASE_URL=wss://testnet.binance.vision/ws
BINANCE_LIVE_WS_BASE_URL=wss://stream.binance.com:9443/ws
# Public WS for last price + book ticker. Replaces REST polling for prices.
BINANCE_MARKET_STREAM_ENABLED=true
BINANCE_MARKET_STREAM_BASE_URL=wss://stream.binance.com:9443
ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT
MAX_NOTIONAL_PER_ORDER=100

MAX_DAILY_LOSS=30
MAX_WEEKLY_LOSS=80
MAX_TRADES_PER_DAY=5
MAX_RISK_PER_TRADE_PERCENT=1
MIN_CONFIDENCE=0.55
MAX_SIGNAL_PRICE_DEVIATION_PERCENT=0.5
DEFAULT_ORDER_QUANTITY=0.001

# Trading cost model. TAKER_FEE_PERCENT applies per leg (entry+exit = 2x).
# SLIPPAGE_ASSUMPTION_PERCENT is a conservative worst-case haircut applied to
# both legs. MIN_REWARD_TO_RISK_RATIO is enforced *after* fees and slippage so
# trades that only look good on paper get rejected before they ever execute.
TAKER_FEE_PERCENT=0.1
SLIPPAGE_ASSUMPTION_PERCENT=0.05
MIN_REWARD_TO_RISK_RATIO=1.5

KILL_SWITCH_ENABLED=true

# Autonomous runner circuit breaker: after N consecutive tick errors the
# runner stops and activates the kill switch. Sleep between iterations
# uses exponential backoff up to MAX_SECONDS while the streak persists.
AUTONOMOUS_CIRCUIT_BREAKER_MAX_CONSECUTIVE_ERRORS=5
AUTONOMOUS_CIRCUIT_BREAKER_BACKOFF_BASE_SECONDS=1.0
AUTONOMOUS_CIRCUIT_BREAKER_BACKOFF_MAX_SECONDS=60.0
